{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    {
      "plugin": "@nx/react",
      "options": {}
    },
    {
      "plugin": "@nx/maven",
      "options": {
        "targetNamePrefix": "mvn-",
        "verbose": false
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "docker:build": {
      "cache": true,
      "dependsOn": ["build"]
    },
    "helm:package": {
      "cache": true
    },
    "mvn-compile": {
      "inputs": ["{projectRoot}/src/**/*"],
      "outputs": ["{projectRoot}/target/classes"]
    },
    "mvn-verify": {
      "dependsOn": ["mvn-compile", "mvn-test"],
      "inputs": ["{projectRoot}/src/**/*", "{projectRoot}/pom.xml"]
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "!{projectRoot}/**/*.spec.ts"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts"
    ]
  },
  "defaultBase": "main"
}

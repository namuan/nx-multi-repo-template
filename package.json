{
  "name": "nx-polyglot-monorepo",
  "private": true,
  "scripts": {
    "nx": "nx",
    "prepare": "husky",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "format": "prettier --write .",
    "check": "tools/check-prereqs.sh",
    "setup": "npm run check && pnpm install && npm run go:tidy && npm run go:sync",
    "go:tidy": "cd apps/api-go && go mod tidy",
    "go:sync": "go work sync",
    "dev:db:up": "docker compose up db -d --wait",
    "dev:db:down": "docker compose stop db",
    "dev:db:reset": "docker compose down -v && npm run dev:db:up",
    "dev:db:logs": "docker compose logs -f db",
    "dev:up": "docker compose up --build",
    "dev:up:demo": "docker compose --profile demo up --build",
    "dev:up:detached": "docker compose up --build -d",
    "dev:down": "docker compose down; tmux kill-session -t fleet-dev 2>/dev/null; true",
    "dev:docker:build": "docker compose build",
    "dev:frontend": "nx run frontend:serve",
    "dev:go": "nx run api-go:serve",
    "dev:java": "nx run api-java:serve",
    "dev:all": "nx run-many -t serve --parallel=3",
    "dev:simulate": "go run ./tools/simulator/main.go",
    "dev:logs:go": "docker compose logs -f api-go",
    "dev:logs:java": "docker compose logs -f api-java",
    "dev:logs:frontend": "docker compose logs -f frontend",
    "dev:logs:all": "tools/tmux/logs-all.sh",
    "test:e2e:backend": "nx run api-e2e:e2e",
    "dev:tmux": "npm run check -- --tmux && tools/tmux/fleet-dev.sh"
  },
  "devDependencies": {
    "@nx-tools/nx-container": "7.2.1",
    "@nx/eslint": "22.5.3",
    "@nx/js": "22.5.3",
    "@nx/playwright": "22.5.3",
    "@nx/react": "22.5.3",
    "@nx/vite": "22.5.3",
    "@nx/vitest": "22.5.3",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^9.0.0",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "lint-staged": "15.5.2",
    "nx": "22.5.3",
    "prettier": "3.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.7.0",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}

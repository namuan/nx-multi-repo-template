{
  "name": "api-java",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:backend", "lang:java"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/api-java/target"],
      "options": {
        "command": "mvn -DskipTests package",
        "cwd": "apps/api-java"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run",
        "cwd": "apps/api-java",
        "env": {
          "JAVA_PORT": "9102"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/api-java",
        "env": {
          "SPRING_DATASOURCE_URL": "jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH",
          "SPRING_DATASOURCE_USERNAME": "sa",
          "SPRING_DATASOURCE_PASSWORD": "",
          "SPRING_DATASOURCE_DRIVER_CLASS_NAME": "org.h2.Driver"
        }
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/api-java/target/site/jacoco"],
      "options": {
        "command": "mvn verify",
        "cwd": "apps/api-java"
      }
    },
    "mvn-process-sources": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn process-sources",
        "cwd": "apps/api-java"
      }
    },
    "mvn-compile": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/api-java/target/classes"],
      "options": {
        "command": "mvn compile",
        "cwd": "apps/api-java"
      }
    },
    "mvn-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/api-java",
        "env": {
          "SPRING_DATASOURCE_URL": "jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH",
          "SPRING_DATASOURCE_USERNAME": "sa",
          "SPRING_DATASOURCE_PASSWORD": "",
          "SPRING_DATASOURCE_DRIVER_CLASS_NAME": "org.h2.Driver"
        }
      }
    },
    "mvn-verify": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn verify",
        "cwd": "apps/api-java",
        "env": {
          "SPRING_DATASOURCE_URL": "jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH",
          "SPRING_DATASOURCE_USERNAME": "sa",
          "SPRING_DATASOURCE_PASSWORD": "",
          "SPRING_DATASOURCE_DRIVER_CLASS_NAME": "org.h2.Driver"
        }
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -DskipTests compile pmd:check pmd:cpd-check spotbugs:check",
        "cwd": "apps/api-java"
      }
    },
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/api-java/Dockerfile -t api-java:latest .",
        "cwd": "{workspaceRoot}"
      }
    },
    "helm:package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "helm package charts/api-java",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}

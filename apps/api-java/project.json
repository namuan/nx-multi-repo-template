{
  "name": "api-java",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:backend", "lang:java"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/api-java/target"],
      "options": {
        "command": "mvn -DskipTests package",
        "cwd": "apps/api-java"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run",
        "cwd": "apps/api-java"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/api-java"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/api-java/target/site/jacoco"],
      "options": {
        "command": "mvn verify",
        "cwd": "apps/api-java"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn checkstyle:check",
        "cwd": "apps/api-java"
      }
    },
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/api-java/Dockerfile -t api-java:latest .",
        "cwd": "{workspaceRoot}"
      }
    },
    "helm:package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "helm package charts/api-java",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}

{
  "name": "api-go",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:backend", "lang:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/api-go"],
      "options": {
        "command": "go build -o ../../dist/apps/api-go/api-go .",
        "cwd": "apps/api-go"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run .",
        "cwd": "apps/api-go",
        "env": {
          "GO_PORT": "9101"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./...",
        "cwd": "apps/api-go"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/api-go"],
      "options": {
        "command": "bash scripts/check-coverage.sh",
        "cwd": "apps/api-go"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{workspaceRoot}/.golangci.yml"
      ],
      "outputs": [],
      "options": {
        "command": "command -v golangci-lint >/dev/null 2>&1 && golangci-lint run ./... --config ../../.golangci.yml || go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.10.1 run ./... --config ../../.golangci.yml",
        "cwd": "apps/api-go"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/.golangci.yml"],
      "outputs": [],
      "options": {
        "command": "command -v golangci-lint >/dev/null 2>&1 && golangci-lint fmt --config ../../.golangci.yml ./... || go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.10.1 fmt --config ../../.golangci.yml ./...",
        "cwd": "apps/api-go"
      }
    },
    "govulncheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{projectRoot}/go.mod", "{projectRoot}/go.sum"],
      "outputs": [],
      "options": {
        "command": "command -v govulncheck >/dev/null 2>&1 && govulncheck ./... || go run golang.org/x/vuln/cmd/govulncheck@latest ./...",
        "cwd": "apps/api-go"
      }
    },
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/api-go/Dockerfile -t api-go:latest .",
        "cwd": "{workspaceRoot}"
      }
    },
    "helm:package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "helm package charts/api-go",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}

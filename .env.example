# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_GO_URL=http://localhost:9101
VITE_API_JAVA_URL=http://localhost:9102

# ── Go API ────────────────────────────────────────────────────────────────────
GO_PORT=8080
DATABASE_URL=postgres://fleet_user:fleet_password@localhost:5432/fleet_db?sslmode=disable
JWT_SECRET=fleet-super-secret-jwt-key-change-in-production
ALLOWED_ORIGIN=http://localhost:9100

# ── Java API ──────────────────────────────────────────────────────────────────
JAVA_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fleet_db
SPRING_DATASOURCE_USERNAME=fleet_user
SPRING_DATASOURCE_PASSWORD=fleet_password
JWT_SECRET=fleet-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_MS=86400000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=fleet_db
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=fleet_password

# ── Simulator ─────────────────────────────────────────────────────────────────
GO_API_URL=http://localhost:9101
INTERVAL_MS=3000
# Local-only startup acceleration (auto-enabled by default when GO_API_URL is localhost)
# Number of immediate synthetic events per device at startup
FAST_FORWARD_EVENTS=40
# Virtual time per warmup event (ms) so positions/odometer advance quickly
FAST_FORWARD_STEP_MS=15000

# ── Deployment ────────────────────────────────────────────────────────────────
IMAGE_TAG=1.0.0


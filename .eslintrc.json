{
  "root": true,
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "coverage/",
    ".nx/"
  ],
  "overrides": [
    {
      "files": ["**/*.{ts,tsx,js,jsx}"],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module",
        "ecmaFeatures": {
          "jsx": true
        }
      },
      "env": {
        "browser": true,
        "node": true,
        "es2022": true
      },
      "rules": {}
    }
  ]
}
